  "source_notes": [
    {
      "entry": "BACKGROUNDAGENT",
      "note": "Cursor Help describes Cloud Agents, formerly Background Agents, as coding agents that run remotely on dedicated virtual machines and can edit, run, and test code."
    },
    {
      "entry": "THEME",
      "note": "The endings refer to fictional agents Ethan Hunt, Johnny English, James Bond, Jim West, Evelyn Salt, and Napoleon Solo."
    },
    {
      "entry": "OSSE",
      "note": "France's SANDRE water registry lists the Osse as a 120-kilometer river; it is a tributary of the Gélise."
    },
    {
      "entry": "ILEUS",
      "note": "Cleveland Clinic defines paralytic ileus as a temporary loss of the intestinal contractions that move food."
    },
    {
      "entry": "FLOR",
      "note": "Foods and Wines from Spain describes flor as the film-forming yeast layer under which fino and manzanilla sherries age."
    },
    {
      "entry": "NEROL",
      "note": "Merriam-Webster defines nerol as a rose-scented liquid alcohol used in perfumery."
    },
    {
      "entry": "ESSE",
      "note": "The Paideia Institute gives esse as the Latin infinitive meaning \"to be.\""
    },
    {
      "entry": "EYEYOGA",
